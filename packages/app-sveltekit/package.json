    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@sveltejs/adapter-node": "5.5.3",
    "@sveltejs/kit": "2.51.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "eslint": "10.0.0",
    "svelte": "5.51.1",
    "svelte-check": "4.4.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vite": "7.3.1"
  }
}

---
interface Props {
  sectionId: string
  label: string
  tab1Label: string
  tab2Label: string
  tab3Label?: string
}

const { sectionId, label, tab1Label, tab2Label, tab3Label } = Astro.props

const tab1Id = `${sectionId}-tab-1`
const tab2Id = `${sectionId}-tab-2`
const tab3Id = `${sectionId}-tab-3`
const panel1Id = `${sectionId}-panel-1`
const panel2Id = `${sectionId}-panel-2`
const panel3Id = `${sectionId}-panel-3`
---

<div class="chart-tabs-container" data-tab-section={sectionId}>
  <div class="chart-tablist" role="tablist" aria-label={label}>
    <button
      type="button"
      role="tab"
      id={tab1Id}
      aria-selected="true"
      aria-controls={panel1Id}
      class="tab active"
    >
      {tab1Label}
    </button>
    <button
      type="button"
      role="tab"
      id={tab2Id}
      aria-selected="false"
      aria-controls={panel2Id}
      class="tab"
    >
      {tab2Label}
    </button>
    {
      tab3Label && (
        <button
          type="button"
          role="tab"
          id={tab3Id}
          aria-selected="false"
          aria-controls={panel3Id}
          class="tab"
        >
          {tab3Label}
        </button>
      )
    }
  </div>
  <div class="chart-tabpanels">
    <div
      role="tabpanel"
      id={panel1Id}
      aria-labelledby={tab1Id}
      class="chart-tabpanel active"
    >
      <slot name="panel-1" />
    </div>
    <div
      role="tabpanel"
      id={panel2Id}
      aria-labelledby={tab2Id}
      class="chart-tabpanel"
      hidden
    >
      <slot name="panel-2" />
    </div>
    {
      tab3Label && (
        <div
          role="tabpanel"
          id={panel3Id}
          aria-labelledby={tab3Id}
          class="chart-tabpanel"
          hidden
        >
          <slot name="panel-3" />
        </div>
      )
    }
  </div>
</div>

<style>
  .chart-tabs-container {
    margin-top: 1.5em;
    margin-bottom: 2em;
  }

  .chart-tablist {
    display: flex;
    gap: 4px;
    margin: 0;
    padding: 0;
    border-bottom: 1px solid var(--ft-border);
  }

  .tab {
    padding: 8px 18px;
    font-size: 14px;
    font-weight: 500;
    color: var(--ft-muted);
    background: transparent;
    border: 1px solid transparent;
    border-bottom: none;
    border-radius: 8px 8px 0 0;
    cursor: pointer;
    font-family: inherit;
    margin-bottom: -1px;
    transition:
      color 0.2s,
      background-color 0.2s,
      border-color 0.2s;
  }

  .tab:hover {
    color: var(--ft-text);
    background: var(--ft-bg-muted);
    border-color: var(--ft-border);
  }

  .tab:focus-visible {
    outline: 2px solid var(--ft-accent);
    outline-offset: 2px;
  }

  .tab.active {
    background: var(--ft-accent);
    color: white;
    border-color: var(--ft-accent);
    /* covers the tablist border-bottom, merging tab into panel */
    border-bottom: 1px solid var(--ft-bg);
  }

  :global(html.dark) .tab.active {
    color: var(--ft-bg);
    border-bottom-color: var(--ft-bg);
  }

  .chart-tabpanels {
    position: relative;
    min-height: 320px;
    border: 1px solid var(--ft-border);
    border-top: none;
    border-radius: 0 0 12px 12px;
    padding: 0.75em 1.25em 1em;
    background: var(--ft-bg);
  }

  .chart-tabpanel[hidden] {
    display: none;
  }

  @media screen and (max-width: 768px) {
    .tab {
      padding: 8px 14px;
      font-size: 13px;
    }
  }
</style>

<script>
  function initTabs() {
    const sections = document.querySelectorAll(
      '.chart-tabs-container[data-tab-section]',
    )
    sections.forEach((section: Element) => {
      const tabs = section.querySelectorAll<HTMLButtonElement>('[role="tab"]')
      const panels = section.querySelectorAll<HTMLElement>('[role="tabpanel"]')

      if (tabs.length === 0 || panels.length === 0) return

      function setActive(index: number) {
        tabs.forEach((tab, i) => {
          const isSelected = i === index
          tab.setAttribute('aria-selected', String(isSelected))
          tab.classList.toggle('active', isSelected)
        })
        panels.forEach((panel, i) => {
          panel.hidden = i !== index
        })
      }

      tabs.forEach((tab, index) => {
        tab.addEventListener('click', () => setActive(index))

        tab.addEventListener('keydown', (e: KeyboardEvent) => {
          let newIndex
          if (e.key === 'ArrowLeft' || e.key === 'ArrowUp') {
            e.preventDefault()
            newIndex = index === 0 ? tabs.length - 1 : index - 1
          } else if (e.key === 'ArrowRight' || e.key === 'ArrowDown') {
            e.preventDefault()
            newIndex = index === tabs.length - 1 ? 0 : index + 1
          } else if (e.key === 'Home') {
            e.preventDefault()
            newIndex = 0
          } else if (e.key === 'End') {
            e.preventDefault()
            newIndex = tabs.length - 1
          } else return
          ;(tabs[newIndex] as HTMLButtonElement).focus()
          setActive(newIndex)
        })
      })

      setActive(0)
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initTabs)
  } else {
    initTabs()
  }
</script>

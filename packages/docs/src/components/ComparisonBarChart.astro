---
import type { ChartDatum } from '../lib/types'

interface Props {
  title: string
  description?: string
  data: ChartDatum[]
  valueFormat: 'count' | 'mb' | 'kb' | 'ms' | 's'
  yAxisLabel: string
}

const CHART_HEIGHT_PX = 400
const MOBILE_CHART_HEIGHT_PX = 300

const { title, description, data, valueFormat, yAxisLabel } = Astro.props
const chartData = data.map((d) => ({
  name: String(d?.name ?? ''),
  value: Math.max(0, Number(d.value) || 0),
  focused: d.focused,
}))
const chartPayload = JSON.stringify({
  data: chartData,
  valueFormat,
  yAxisLabel,
})
---

<div class="comparison-chart">
  <h3 class="comparison-chart-title">{title}</h3>
  {description ? <p>{description}</p> : null}
  <div class="comparison-chart-wrapper" data-comparison={chartPayload}>
    <canvas aria-label={title} role="img">{title} chart</canvas>
  </div>
</div>

<style
  define:vars={{
    chartHeight: `${CHART_HEIGHT_PX}px`,
    mobileChartHeight: `${MOBILE_CHART_HEIGHT_PX}px`,
  }}
>
  .comparison-chart {
    width: 100%;
    margin-bottom: 2em;
  }

  .comparison-chart-title {
    font-size: 16px;
  }

  .comparison-chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 1000px;
    height: var(--chartHeight);
    margin-inline: auto;
  }

  @media (max-width: 768px) {
    .comparison-chart-wrapper {
      height: var(--mobileChartHeight);
    }
  }
</style>

<script>
  import {
    BarController,
    BarElement,
    CategoryScale,
    Chart,
    Legend,
    LinearScale,
    Tooltip,
  } from 'chart.js'
  import type { ChartDatum, ComparisonChartPayload } from '../lib/types'

  Chart.register(
    BarController,
    BarElement,
    CategoryScale,
    Legend,
    LinearScale,
    Tooltip,
  )

  const chartCache = new WeakMap<HTMLCanvasElement, Chart>()
  const BAR_COLOR = '#c0b9dd'
  const BAR_HOVER_COLOR = '#b2a8d8'
  const MIN_BAR_LENGTH = 4
  const TEXT_COLOR_FALLBACK = '#1f2933'
  const MUTED_COLOR_FALLBACK = '#697586'
  const BORDER_COLOR_FALLBACK = '#d9dee7'

  function formatValue(
    value: number,
    format: 'count' | 'mb' | 'kb' | 'ms' | 's',
  ): string {
    if (format === 'count') return String(Math.round(value))
    if (format === 'mb') return `${value.toFixed(2)} MB`
    if (format === 'kb') return `${value.toFixed(2)} KB`
    if (format === 's') return `${value.toFixed(2)}s`
    return `${value.toFixed(2)} ms`
  }

  function formatAxisTick(
    value: string | number,
    format: 'count' | 'mb' | 'kb' | 'ms' | 's',
  ): string {
    const numericValue = Number(value)

    if (!Number.isFinite(numericValue)) return ''
    if (format !== 'count') return formatValue(numericValue, format)
    if (!Number.isInteger(numericValue)) return ''

    return String(numericValue)
  }

  function getCssVar(element: Element, name: string, fallback: string) {
    return getComputedStyle(element).getPropertyValue(name).trim() || fallback
  }

  function getData(wrapper: HTMLElement): {
    payload: ComparisonChartPayload
    data: ChartDatum[]
  } | null {
    const dataAttr = wrapper.dataset.comparison
    if (!dataAttr) return null

    let payload: ComparisonChartPayload
    try {
      payload = JSON.parse(dataAttr) as ComparisonChartPayload
    } catch (e) {
      console.warn('[ComparisonBarChart] Invalid chart data:', e)
      return null
    }

    const scopedParent = wrapper.closest<HTMLElement>('[data-framework-scope]')
    const focusedOnly = scopedParent?.dataset.frameworkScope === 'focused'
    const data = payload.data.filter((d) => !focusedOnly || d.focused !== false)

    return { payload, data }
  }

  function initChart(wrapper: HTMLElement) {
    const canvas = wrapper.querySelector('canvas')
    if (!canvas) return
    const chartTitle = canvas.getAttribute('aria-label') ?? 'Comparison'

    const result = getData(wrapper)
    if (!result || result.data.length === 0) return

    const { payload, data } = result
    const values = data.map((d) => d.value)
    const max = Math.max(...values)
    const suggestedMax =
      payload.valueFormat === 'count' ? Math.max(1, Math.ceil(max)) : max * 1.05
    const root = document.documentElement
    const textColor = getCssVar(root, '--ft-text', TEXT_COLOR_FALLBACK)
    const mutedColor = getCssVar(root, '--ft-muted', MUTED_COLOR_FALLBACK)
    const borderColor = getCssVar(root, '--ft-border', BORDER_COLOR_FALLBACK)
    const gridColor = getCssVar(root, '--ft-chart-grid', borderColor)
    const barColor = getCssVar(root, '--ft-chart-bar', BAR_COLOR)
    const barHoverColor = getCssVar(
      root,
      '--ft-chart-bar-hover',
      BAR_HOVER_COLOR,
    )

    chartCache.get(canvas)?.destroy()

    const chart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: data.map((d) => d.name),
        datasets: [
          {
            label: payload.yAxisLabel ?? chartTitle,
            data: values,
            borderRadius: 4,
            borderSkipped: false,
            minBarLength: MIN_BAR_LENGTH,
            backgroundColor: barColor,
            hoverBackgroundColor: barHoverColor,
          },
        ],
      },
      options: {
        animation: { duration: 500 },
        maintainAspectRatio: false,
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) =>
                formatValue(Number(context.raw ?? 0), payload.valueFormat),
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              color: textColor,
              maxRotation: 45,
              minRotation: 45,
              font: { size: 12, weight: 500 },
            },
          },
          y: {
            beginAtZero: true,
            suggestedMax,
            border: { color: gridColor },
            grid: { color: gridColor },
            title: {
              color: mutedColor,
              display: Boolean(payload.yAxisLabel),
              font: { size: 12, weight: 600 },
              text: payload.yAxisLabel,
            },
            ticks: {
              color: mutedColor,
              font: { size: 12 },
              precision: payload.valueFormat === 'count' ? 0 : undefined,
              callback: (value) => formatAxisTick(value, payload.valueFormat),
            },
          },
        },
      },
    })

    chartCache.set(canvas, chart)
  }

  function initCharts() {
    document
      .querySelectorAll<HTMLElement>('.comparison-chart-wrapper')
      .forEach(initChart)
  }

  function scheduleInit() {
    requestAnimationFrame(initCharts)
  }

  function observeThemeChanges() {
    if (typeof MutationObserver === 'undefined') return

    let lastThemeState = `${document.documentElement.className}:${document.documentElement.dataset.theme ?? ''}`
    const observer = new MutationObserver(() => {
      const nextThemeState = `${document.documentElement.className}:${document.documentElement.dataset.theme ?? ''}`
      if (nextThemeState === lastThemeState) return

      lastThemeState = nextThemeState
      scheduleInit()
    })

    observer.observe(document.documentElement, {
      attributeFilter: ['class', 'data-theme'],
      attributes: true,
    })
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initCharts())
  } else {
    initCharts()
  }

  observeThemeChanges()
</script>

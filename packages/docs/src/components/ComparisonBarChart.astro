---
import type { ChartDatum } from '../lib/types'

interface Props {
  title: string
  data: ChartDatum[]
  valueFormat: 'count' | 'mb' | 'kb' | 'ms' | 's'
  yAxisLabel: string
  sortDirection: 'asc' | 'desc'
}

const CHART_HEIGHT_PX = 400
const MOBILE_CHART_HEIGHT_PX = 300

const { title, data, valueFormat, yAxisLabel, sortDirection } = Astro.props
const sortMultiplier = sortDirection === 'desc' ? -1 : 1
const sortedData = data
  .map((d) => ({
    name: String(d?.name ?? ''),
    value: Math.max(0, Number(d.value) || 0),
    focused: d.focused,
  }))
  .sort(
    (a, b) =>
      (a.value - b.value) * sortMultiplier || a.name.localeCompare(b.name),
  )
const chartPayload = JSON.stringify({
  data: sortedData,
  valueFormat,
  yAxisLabel,
})
---

<div class="comparison-chart">
  <h3 class="comparison-chart-title">{title}</h3>
  <div class="comparison-chart-wrapper" data-comparison={chartPayload}>
    <canvas aria-label={title} role="img">{title} chart</canvas>
  </div>
</div>

<style
  define:vars={{
    chartHeight: `${CHART_HEIGHT_PX}px`,
    mobileChartHeight: `${MOBILE_CHART_HEIGHT_PX}px`,
  }}
>
  .comparison-chart {
    width: 100%;
    margin-top: 0;
    margin-bottom: 2em;
  }

  .comparison-chart-title {
    font-size: 16px;
    font-weight: 600;
    color: var(--ft-text);
    margin: 0 0 0.75em;
  }

  .comparison-chart-wrapper {
    position: relative;
    width: 100%;
    max-width: 1000px;
    height: var(--chartHeight);
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .comparison-chart-wrapper {
      height: var(--mobileChartHeight);
    }
  }
</style>

<script>
  import Chart from 'chart.js/auto'
  import type { ChartDatum, ComparisonChartPayload } from '../lib/types'

  const chartCache = new WeakMap<HTMLCanvasElement, Chart>()
  const resizeObserverCache = new WeakMap<HTMLElement, ResizeObserver>()
  const BAR_COLOR = '#c0b9dd'
  const MIN_BAR_LENGTH = 4
  const TEXT_COLOR_FALLBACK = '#1f2933'
  const MUTED_COLOR_FALLBACK = '#697586'
  const BORDER_COLOR_FALLBACK = '#d9dee7'

  function formatValue(
    value: number,
    format: 'count' | 'mb' | 'kb' | 'ms' | 's',
  ): string {
    if (format === 'count') return String(Math.round(value))
    if (format === 'mb') return `${value.toFixed(2)} MB`
    if (format === 'kb') return `${value.toFixed(2)} KB`
    if (format === 's') return `${value.toFixed(2)}s`
    return `${value.toFixed(2)} ms`
  }

  function getCssVar(element: Element, name: string, fallback: string) {
    return getComputedStyle(element).getPropertyValue(name).trim() || fallback
  }

  function getData(wrapper: HTMLElement): {
    payload: ComparisonChartPayload
    data: ChartDatum[]
  } | null {
    const dataAttr = wrapper.dataset.comparison
    if (!dataAttr) return null

    let payload: ComparisonChartPayload
    try {
      payload = JSON.parse(dataAttr) as ComparisonChartPayload
    } catch (e) {
      console.warn('[ComparisonBarChart] Invalid chart data:', e)
      return null
    }

    const toggle = document.getElementById(
      'focused-toggle',
    ) as HTMLInputElement | null
    const focusedOnly = toggle ? toggle.checked : false
    const data = payload.data.filter((d) => !focusedOnly || d.focused !== false)

    return { payload, data }
  }

  function initChart(wrapper: HTMLElement) {
    if (wrapper.offsetParent === null) return

    const canvas = wrapper.querySelector('canvas')
    if (!canvas) return
    const chartTitle = canvas.getAttribute('aria-label') ?? 'Comparison'

    const result = getData(wrapper)
    if (!result || result.data.length === 0) return

    const { payload, data } = result
    const values = data.map((d) => d.value)
    const max = Math.max(...values)
    const root = document.documentElement
    const textColor = getCssVar(root, '--ft-text', TEXT_COLOR_FALLBACK)
    const mutedColor = getCssVar(root, '--ft-muted', MUTED_COLOR_FALLBACK)
    const borderColor = getCssVar(root, '--ft-border', BORDER_COLOR_FALLBACK)
    const gridColor = getCssVar(root, '--ft-chart-grid', borderColor)

    chartCache.get(canvas)?.destroy()

    const chart = new Chart(canvas, {
      type: 'bar',
      data: {
        labels: data.map((d) => d.name),
        datasets: [
          {
            label: payload.yAxisLabel ?? chartTitle,
            data: values,
            borderRadius: 4,
            borderSkipped: false,
            minBarLength: MIN_BAR_LENGTH,
            backgroundColor: BAR_COLOR,
            hoverBackgroundColor: BAR_COLOR,
          },
        ],
      },
      options: {
        animation: { duration: 500 },
        maintainAspectRatio: false,
        responsive: true,
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (context) =>
                formatValue(Number(context.raw ?? 0), payload.valueFormat),
            },
          },
        },
        scales: {
          x: {
            grid: { display: false },
            ticks: {
              color: textColor,
              maxRotation: 45,
              minRotation: 45,
              font: { size: 12, weight: 500 },
            },
          },
          y: {
            beginAtZero: true,
            suggestedMax: max * 1.05,
            border: { color: gridColor },
            grid: { color: gridColor },
            title: {
              color: mutedColor,
              display: Boolean(payload.yAxisLabel),
              font: { size: 12, weight: 600 },
              text: payload.yAxisLabel,
            },
            ticks: {
              color: mutedColor,
              font: { size: 12 },
              callback: (value) =>
                payload.valueFormat === 'count'
                  ? String(Math.round(Number(value)))
                  : formatValue(Number(value), payload.valueFormat),
            },
          },
        },
      },
    })

    chartCache.set(canvas, chart)

    if (typeof ResizeObserver !== 'undefined') {
      resizeObserverCache.get(wrapper)?.disconnect()
      const ro = new ResizeObserver(() => chart.resize())
      ro.observe(wrapper)
      resizeObserverCache.set(wrapper, ro)
    }
  }

  function initCharts(root: ParentNode = document) {
    root
      .querySelectorAll<HTMLElement>('.comparison-chart-wrapper')
      .forEach(initChart)
  }

  function scheduleInit(root?: ParentNode) {
    requestAnimationFrame(() => initCharts(root))
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => initCharts())
  } else {
    initCharts()
  }

  window.addEventListener('focused-toggle', () => initCharts())
  document.addEventListener('chart-tabpanel-active', (event) => {
    const panel = (event as CustomEvent<{ panel?: ParentNode }>).detail?.panel
    if (panel) scheduleInit(panel)
  })
</script>

---
import CoreWebVitalChart from './CoreWebVitalChart.astro'
import type { Device } from '../lib/collections'

interface Props {
  device: Device
}

const { device } = Astro.props
---

<CoreWebVitalChart cwv="lcp" device={device} />
<CoreWebVitalChart cwv="cls" device={device} />
<CoreWebVitalChart cwv="fcp" device={device} />
<CoreWebVitalChart cwv="ttfb" device={device} />
<CoreWebVitalChart cwv="inp" device={device} />

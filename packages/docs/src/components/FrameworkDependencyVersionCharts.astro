---
import VersionLineChart from './VersionLineChart.astro'

interface Props {
  versions: unknown[]
}

const { versions } = Astro.props
---

<VersionLineChart
  title="Production Dependencies"
  versions={versions}
  metric="prodDependencies"
  seriesStyle="points"
  valueFormat="count"
  yAxisLabel="Dependencies"
/>
<VersionLineChart
  title="Development Dependencies"
  versions={versions}
  metric="devDependencies"
  seriesStyle="points"
  valueFormat="count"
  yAxisLabel="Dependencies"
/>
<VersionLineChart
  title="All Dependencies"
  versions={versions}
  metric="allDependencies"
  seriesStyle="points"
  valueFormat="count"
  yAxisLabel="Dependencies"
/>
<VersionLineChart
  title="Duplicate Dependencies"
  versions={versions}
  metric="duplicateDependencies"
  seriesStyle="points"
  valueFormat="count"
  yAxisLabel="Duplicates"
/>

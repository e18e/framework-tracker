---
import VersionLineChart from './VersionLineChart.astro'

interface Props {
  versions: unknown[]
}

const { versions } = Astro.props
---

<VersionLineChart
  title="Ops/sec"
  versions={versions}
  metric="ssrRequestThroughputTests.opsPerSec"
  valueFormat="count"
  yAxisLabel="Operations per second"
/>
<VersionLineChart
  title="Body Size"
  versions={versions}
  metric="ssrRequestThroughputTests.bodySizeKb"
  valueFormat="kb"
  yAxisLabel="Kilobytes"
/>
<VersionLineChart
  title="Median Latency"
  versions={versions}
  metric="ssrRequestThroughputTests.medianLatencyMs"
  valueFormat="ms"
  yAxisLabel="Milliseconds"
/>

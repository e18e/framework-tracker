---
import BuildSizeCharts from '../components/BuildSizeCharts.astro'
import BrowserBaselineTable from '../components/BrowserBaselineTable.astro'
import CoreJsTable from '../components/CoreJsTable.astro'
import DependencyCharts from '../components/DependencyCharts.astro'
import ServerSideRenderedCharts from '../components/ServerSideRenderedCharts.astro'
import NodeModulesSizeCharts from '../components/NodeModulesSizeCharts.astro'
import Description from '../components/Description.astro'
import DetailsLink from '../components/DetailsLink.astro'
import PageHeader from '../components/PageHeader.astro'
import ClientSideRenderedCharts from '../components/ClientSideRenderedCharts.astro'
import SSRLoadP99Charts from '../components/SSRLoadP99Charts.astro'
import SSRRequestThroughputCharts from '../components/SSRRequestThroughputCharts.astro'
import Layout from '../layouts/Layout.astro'
import DepotLogo from '../assets/depot-logo-horizontal.svg'
---

<Layout>
  <PageHeader showToggle>Framework Tracker</PageHeader>
  <Description>
    For a full list of what we plan to track see{' '}
    <a
      href="https://github.com/e18e/framework-tracker/blob/main/initial-comparison-list.md"
      target="_blank"
      rel="noopener noreferrer"
      class="roadmap-link"
    >
      roadmap</a
    >.
  </Description>
  <Description>
    Stats are currently in active development and may change as we refine our
    methodology and testing process.
  </Description>

  <div class="depot">
    <p>
      All of the testing and stat generation is run by our Infrastructure
      Partner Depot to ensure consistent, fairer, and faster testing.
    </p>

    <a
      href="https://depot.dev/"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Depot"
    >
      <DepotLogo class="logo logo-light" />
    </a>
  </div>

  <h2>Dev Time Performance</h2>
  <h3>Dependency Counts</h3>
  <DependencyCharts />
  <DetailsLink
    href="/methodology#dependency-counts"
    label="Dependency Counts"
  />
  <h3>Node Modules Size</h3>
  <NodeModulesSizeCharts />
  <DetailsLink
    href="/methodology#node-modules-size"
    label="Node Modules Size"
  />
  <h3>Build Times</h3>
  <BuildSizeCharts />
  <DetailsLink
    href="/methodology#build-and-install-times"
    label="Build and Install Times"
  />
  <h3>Core-JS Polyfills</h3>
  <CoreJsTable />
  <DetailsLink
    href="/methodology#core-js-polyfills"
    label="Core-JS Polyfills"
  />
  <h3>Browser Baseline</h3>
  <BrowserBaselineTable />
  <DetailsLink href="/methodology#browser-baseline" label="Browser Baseline" />
  <h2>Runtime Performance</h2>
  <h3>Client Side Rendered Tests</h3>
  <ClientSideRenderedCharts />
  <DetailsLink
    href="/methodology#client-side-rendered-tests"
    label="Client Side Rendered Tests"
  />
  <h3>Server Side Rendered Tests</h3>
  <ServerSideRenderedCharts />
  <DetailsLink
    href="/methodology#server-side-rendered-tests"
    label="Server Side Rendered Tests"
  />
  <h3>Server Side Throughput Tests</h3>
  <SSRRequestThroughputCharts />
  <DetailsLink
    href="/methodology#server-side-throughput-tests"
    label="Server Side Throughput Tests"
  />
  <h3>Server Side Load Test</h3>
  <SSRLoadP99Charts />
  <DetailsLink
    href="/methodology#server-side-load-test"
    label="Server Side Load Test"
  />
</Layout>

<style>
  .roadmap-link {
    font-weight: 500;
  }

  .depot {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px;

    p {
      color: var(--ft-muted);
      flex: 1 1 66%;
    }

    :global(svg) {
      height: 42px;
      width: auto;
    }
  }
</style>
